
#include <string>
#include <iostream>
#include <iomanip>
#include <sstream>

#include <UnigineMathLib.h>
#include <UnigineFileSystem.h>
#include <UnigineWorld.h>

#include "unigine2_graphics/collapsible_widget.h"

#include "import_ground_height_gui.h"
#include "unigine2_graphics/unigine2_utilities.h"

import_ground_height_gui::import_ground_height_gui()
{

    // translation dictionary is currently added to the world builder main gui, which happens to also be the main window gui
    // so to provide translations we need to translate through that,
    // for now, instead of getting the world builder GUI, we are getting the main window ourselves.
    // maybe using .ui files makes this a bit cleaner?
    Unigine::EngineWindowPtr main_window = Unigine::WindowManager::getMainWindow();
    auto gui = main_window->getGui();

    // this is our main collabisble widget that we are creating for someone to add to a gui somewhere.
    m_collapsible_widget = std::shared_ptr<CollapsibleWidget>(new CollapsibleWidget(gui->translate("Import Ground Height")));
    // initialise our gui to hidden
    m_collapsible_widget->hide();

    // the create a container just for the collapsible content widget
    // we don't do anything special on this widget, we will leave it to the widgets we add to it to make it
    // easier to separate those out if they were to go somewhere else.
    auto collapsible_content_container = Unigine::WidgetVBox::create(0, 2);
    m_collapsible_widget->addContentWidget(collapsible_content_container);

    // the actual container of our components
    auto main_content_container = Unigine::WidgetVBox::create(0, 4);
    collapsible_content_container->addChild(main_content_container);

    // container for our file selection 
    auto image_selection_container = Unigine::WidgetHBox::create(5, 0);

    // edit line label
    auto image_selection_label = unigine2_ui::CreateWidgetLabel(gui->translate("File Path:"), 60, 20);
    image_selection_label->setTextAlign(Unigine::Gui::ALIGN_LEFT); // | Unigine::Gui::ALIGN_BOTTOM
    // edit line
    auto image_selection_edit = unigine2_ui::CreatePropertyEditLineLabel(200, 20, 1, true);

    image_selection_container->addChild(image_selection_label);
    image_selection_container->addChild(image_selection_edit);

    auto file_dialog_open_button = Unigine::WidgetButton::create();
    file_dialog_open_button->setWidth(40);
    file_dialog_open_button->setHeight(30);
    // TODO: BE BETTER
    //auto open_image = Unigine::Image::create(Unigine::FileSystem::resolvePartialVirtualPath("file_open.png"));
    //open_image->resize(20, 20);
    //file_dialog_open_button->setImage(open_image);
    //file_dialog_open_button->setWidth(20); //40
    //file_dialog_open_button->setHeight(20); //30
    file_dialog_open_button->setText(gui->translate("Open"));
    file_dialog_open_button->setToolTip(gui->translate("Browse for a file to import"));
    file_dialog_open_button->setTextAlign(Unigine::Gui::ALIGN_CENTER);
    file_dialog_open_button->arrange();
    
    // creating a button widget to display the file dialog
    image_selection_container->addChild(file_dialog_open_button, Unigine::Gui::ALIGN_BOTTOM);


    // creating a file dialog widget and setting its caption, default path and file extensions filter to display only *.png and *.jpeg files
    auto file_dialog = Unigine::WidgetDialogFile::create("Select a file...");
    file_dialog->setPath("./");
    // TODO: validate file has correct channel data for height field. but where?
    std::stringstream filter_string;
    auto supported_image_extensions = Unigine::Image::getSupportedLoadExtensions();
    for (auto &ext : supported_image_extensions)
    {
        filter_string << "." << ext.get();
    }

    file_dialog->setFilter(filter_string.str().c_str());

    file_dialog->getOkButton()->getEventClicked().connectUnsafe(
        [file_dialog, image_selection_edit](const Unigine::WidgetPtr &ok_button_widget, int mouse_buttons) {
        // getting the current path selection from the dialog and checking if the file exists
        Unigine::String path = file_dialog->getFile();
        if (!Unigine::FileSystem::isFileExist(path))
            return;

        // if the file exists hiding the dialog, displaying the selected file on the "file_name" label and removing focus
        file_dialog->setHidden(true);
        file_dialog->setEnabled(false);
        image_selection_edit->setText(path);
        file_dialog->removeFocus(); }
    );

    file_dialog->getCancelButton()->getEventClicked().connectUnsafe(
        [file_dialog](const Unigine::WidgetPtr &cancel_button_widget, int mouse_buttons) {
        // resetting file selection, showing the dialog and setting permanent focus to it
        file_dialog->setHidden(true);
        file_dialog->setEnabled(false);
        file_dialog->removeFocus(); }
    );


    // adding the created file dialog widget to the system GUI and hiding it
    file_dialog->setHidden(true);
    file_dialog->setEnabled(false);
    file_dialog->setIntersectionEnabled(false);
    file_dialog->removeFocus();
    gui->addChild(file_dialog, Unigine::Gui::ALIGN_OVERLAP | Unigine::Gui::ALIGN_CENTER);

    // setting "on_button_clicked" function to handle CLICKED event for the button
    file_dialog_open_button->getEventClicked().connectUnsafe(
        [file_dialog](const Unigine::WidgetPtr &open_button_widget, int mouse_buttons) {
        // resetting file selection, showing the dialog and setting permanent focus to it
        file_dialog->setFile("");
        file_dialog->setHidden(false);
        file_dialog->setEnabled(true);
        file_dialog->setPermanentFocus(); }
    );


    main_content_container->addChild(image_selection_container, Unigine::Gui::ALIGN_EXPAND);

    // container for applying the import
    auto buttons_container = Unigine::WidgetHBox::create(5, 0);

    // container for our height data input
    auto height_value_container = Unigine::WidgetVBox::create(0, 4);
    auto min_height_value_container = Unigine::WidgetHBox::create(5, 0);
    auto max_height_value_container = Unigine::WidgetHBox::create(5, 0);

    // height scaling values.
    // should be able to be enabled/disabled if the images have raw heights in them already (to avoid having to enter the min/max to scale back to the original)
    auto min_height_label = unigine2_ui::CreateWidgetLabel(gui->translate("Minimum Height"), 60, 20);
    min_height_label->setTextAlign(Unigine::Gui::ALIGN_LEFT); //| Unigine::Gui::ALIGN_BOTTOM
    // edit line
    auto min_height_edit = unigine2_ui::CreatePropertyEditLineLabel(40, 20, 1, true);
    min_height_edit->setValidator(Unigine::Gui::VALIDATOR_FLOAT);

    auto max_height_label = unigine2_ui::CreateWidgetLabel(gui->translate("Maximum Height"), 60, 20);
    max_height_label->setTextAlign(Unigine::Gui::ALIGN_LEFT); // | Unigine::Gui::ALIGN_BOTTOM
    // edit line
    auto max_height_edit = unigine2_ui::CreatePropertyEditLineLabel(40, 20, 1, true);
    max_height_edit->setValidator(Unigine::Gui::VALIDATOR_FLOAT);

    min_height_value_container->addChild(min_height_label, Unigine::Gui::ALIGN_EXPAND);
    min_height_value_container->addChild(min_height_edit, Unigine::Gui::ALIGN_EXPAND);
    max_height_value_container->addChild(max_height_label, Unigine::Gui::ALIGN_EXPAND);
    max_height_value_container->addChild(max_height_edit, Unigine::Gui::ALIGN_EXPAND);
    height_value_container->addChild(min_height_value_container, Unigine::Gui::ALIGN_EXPAND);
    height_value_container->addChild(max_height_value_container, Unigine::Gui::ALIGN_EXPAND);

    // check box to enable scaling
    max_height_edit->setValidator(Unigine::Gui::VALIDATOR_FLOAT);
    auto scale_heights_checkbox = Unigine::WidgetCheckBox::create(gui->translate("Enable Height Scaling"));
    // set it on by default
    scale_heights_checkbox->setChecked(1);

    scale_heights_checkbox->getEventChanged().connectUnsafe(
        [height_value_container](const Unigine::WidgetPtr &height_scale_enabled_widget) {
            auto widget = Unigine::checked_ptr_cast<Unigine::WidgetCheckBox>(height_scale_enabled_widget);
            if (widget->isValid())
            {
                height_value_container->setHidden(!widget->isChecked());
            }
        }
    );

    buttons_container->addChild(scale_heights_checkbox, Unigine::Gui::ALIGN_LEFT);

    auto import_button = Unigine::WidgetButton::create();
    import_button->setWidth(40);
    import_button->setHeight(30);
    import_button->setText(gui->translate("Import"));
    import_button->setTextAlign(Unigine::Gui::ALIGN_CENTER);
    import_button->arrange();

    import_button->getEventClicked().connectUnsafe(
        [image_selection_edit, scale_heights_checkbox, min_height_edit, max_height_edit, this](const Unigine::WidgetPtr &open_button_widget, int mouse_buttons)
    {
        std::string path = image_selection_edit->getText();
        if (!Unigine::FileSystem::isFileExist(path.c_str()))
            return;

        auto apply_scaling = scale_heights_checkbox->isChecked();
        auto min_height = Unigine::String::atof(min_height_edit->getText());
        auto max_height = Unigine::String::atof(max_height_edit->getText());

        if (m_import_cb)
            m_import_cb(path, apply_scaling, min_height, max_height);
    }
    );

    import_button->setToolTip(gui->translate("Apply the new ground image file."));
    buttons_container->addChild(import_button, Unigine::Gui::ALIGN_RIGHT);

    main_content_container->addChild(buttons_container, Unigine::Gui::ALIGN_EXPAND);
    main_content_container->addChild(height_value_container, Unigine::Gui::ALIGN_EXPAND);

}

Unigine::WidgetPtr import_ground_height_gui::GetWidget()
{
    return Unigine::checked_ptr_cast<Unigine::Widget>(m_collapsible_widget->get());
}

void import_ground_height_gui::Show()
{
    m_collapsible_widget->show();
}

void import_ground_height_gui::Hide()
{
    m_collapsible_widget->hide();
}

