#pragma once

#include "terrain_manipulator.h"
#include "pull_terrain_to_surface_gui.h"

#include <UnigineObjects.h>
#include <cassert>
#include <string>
#include <vector>
#include <regex>



class terrain_to_surface
{
public:
    terrain_to_surface(terrain_manipulator &terrain_manipulator);
    ~terrain_to_surface();

    void update();

    void show_ui() { m_terrain_to_surface_gui->Show(); }
    void hide_ui() { m_terrain_to_surface_gui->Hide(); }

    Unigine::WidgetPtr get_gui_wiget() { return m_terrain_to_surface_gui->GetWidget(); }

    // Blend mode for the brush height operations
    // Note that this is not the same as Unigine::Landscape::BLENDING_MODE enum
    // which is for blending between lmpas 
    enum PullTargetMode
    {
        SurfaceProperty = 0,
        BoundingBox = 1
    };

    void SetGetSelectionCallback(std::function<std::vector<Unigine::NodePtr>()> func) { m_get_selection_func = func; }

    // farm out to logic based on selection
    void RaiseTerrainToSelection(
        std::vector<Unigine::NodePtr> nodes,
        float flat_distance,
        float falloff_distance,
        float bias,
        float smoothing,
        int target_layer_order = 0);

    // circular pull to bottom of bounding box of node
    void RaiseTerrainToBoundingBox(Unigine::NodePtr node, float flat_size, float falloff_size, int target_layer_order = 0);

    void RaiseTerrainToSurfaces(
        std::vector<Unigine::NodePtr> nodes,
        Unigine::PropertyPtr target_surface_property,
        float flat_distance,
        float falloff_distance,
        float bias,
        float smoothing,
        int target_layer_order = 0);

    // externaly configure the mode of pulling terrain
    void SetPullTargetMode(PullTargetMode in_pull_target_mode);

private:

    void FindTerrainTiles(Unigine::NodePtr, Unigine::Vector<Unigine::LandscapeLayerMapPtr>& lmap_nodes, const char* target_lmap_name = "");

private:

    terrain_manipulator &m_terrain_manipulator;

    std::function<std::vector<Unigine::NodePtr>()> m_get_selection_func;

    std::unique_ptr<pull_terrain_to_surface_gui> m_terrain_to_surface_gui;

    PullTargetMode m_pull_target_mode{ PullTargetMode::SurfaceProperty };

    // Modified by all the async callbacks to keep track of what is goign on behind the scenes
    int m_async_operations_count {0};

};