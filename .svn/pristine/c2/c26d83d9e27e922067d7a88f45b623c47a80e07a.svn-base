#include "terrain_painting.h"
#include "terrain_manipulator.h"

#include "TerrainHelper.h"

#include <UnigineWorld.h>
#include <UnigineObjects.h>
#include <UnigineEngine.h>
#include <UnigineGame.h>



terrain_painting::terrain_painting(terrain_manipulator &terrain_manipulator)
    :m_terrain_manipulator(terrain_manipulator)
{

    Unigine::EngineWindowPtr main_window = Unigine::WindowManager::getMainWindow();
    auto gui = main_window->getGui();

    load_brush_textures();

    // construct our gui and hook up callbacks to update our values when teh gui changes.
    // We own the state of the brush configuration ratehr than the gui owning the state so that we
    // can operate without gui.
    m_terrain_paint_gui = std::make_unique<terrain_paint_gui>(gui, brush_textures_icons, brush_size, brush_angle, brush_height, brush_opacity, static_cast<int>(height_blend_mode));

    m_terrain_paint_gui->SetSelectBrushTextureCallback(
        [this](int texture_index)
        {
            auto in_brush_texture = brush_textures[texture_index];
            Unigine::Log::message("setting texture to %s\n", in_brush_texture->getDebugName());

            this->set_brush_texture(in_brush_texture);
        }
    );

    m_terrain_paint_gui->SetToggleCallback(
        [this](bool edit_mode_enabled)
        {
            set_terrain_paint_mode(edit_mode_enabled);
        }
    );

    m_terrain_paint_gui->SetBrushSizeCallback(
        [this](float brush_size)
    {
        this->set_brush_size(brush_size);
    }
    );
    m_terrain_paint_gui->SetBrushAngleCallback(
        [this](float brush_angle)
    {
        this->set_brush_angle(brush_angle);
    }
    );
    m_terrain_paint_gui->SetBrushHeightCallback(
        [this](float brush_height)
    {
        this->brush_height = brush_height;
    }
    );
    m_terrain_paint_gui->SetBrushOpacityCallback(
        [this](float brush_opacity)
    {
        this->brush_opacity = brush_opacity;
    }
    );
    m_terrain_paint_gui->SetHeightBlendModeCallback(
        [this](int height_blend_mode)
    {
        this->height_blend_mode = static_cast<terrain_manipulator::HeightBlendMode>(height_blend_mode);
    }
    );

    landscape_fetch = Unigine::LandscapeFetch::create();


}

terrain_painting::~terrain_painting()
{

}

void terrain_painting::update()
{
    // nothing to do if we are not editing
    if (!m_edit_mode_enabled)
        return;

    Unigine::EngineWindowPtr main_window = Unigine::WindowManager::getMainWindow();
    auto                     gui = main_window->getGui();

    // get the current player (camera)
    Unigine::PlayerPtr player = Unigine::Game::getPlayer();
    if (player.get() == NULL)
        return;

    Unigine::CameraPtr camera = player->getCamera();

    // check that the GUI was under the cursor 
    if (!gui->isUnderCursor())
    {
        return;
    }

    auto widget_under_cursor = gui->getUnderCursorWidget();
    if (widget_under_cursor)
    {
        return;
    }

    if (Unigine::Input::isKeyPressed(Unigine::Input::KEY_ANY_SHIFT))
    {
        auto new_brush_angle = brush_angle + Unigine::Input::getMouseWheel() * 5;
        set_brush_angle(brush_angle);
        m_terrain_paint_gui->set_brush_angle(new_brush_angle);
    }
    else if (Unigine::Input::isKeyPressed(Unigine::Input::KEY_ANY_CTRL))
    {
        auto new_brush_size = brush_size + Unigine::Input::getMouseWheel() * 0.5f;
        set_brush_size(new_brush_size);
        m_terrain_paint_gui->set_brush_size(brush_size);
    }
    else if (Unigine::Input::isKeyPressed(Unigine::Input::KEY_ANY_ALT))
    {
        auto new_brush_opacity = brush_opacity + Unigine::Input::getMouseWheel() * 0.05f;
        set_brush_opacity(new_brush_opacity);
        m_terrain_paint_gui->set_brush_opacity(brush_opacity);
    }
    else if (Unigine::Input::isKeyPressed(Unigine::Input::KEY_C))
    {
        // continuously sample if holding c? otherwise we can move it to a shortcut only on press?
        const auto mouse_coord = Unigine::Input::getMousePosition();
        bool fetched = landscape_fetch->intersectionForce(player->getPosition(),
            player->getPosition() + Unigine::Math::Vec3(player->getDirectionFromMainWindow(mouse_coord.x, mouse_coord.y)) * 10000.0);

        if (fetched)
        {
            auto new_brush_height = landscape_fetch->getPosition().z;
            this->brush_height= new_brush_height;
            m_terrain_paint_gui->set_brush_height(new_brush_height);
            // might be nice to show a "grabber" tool in some way and hide the decal, but for now, just update the decal here as we wont call any further.
            //brush_decal->setPosition(landscape_fetch->getPosition() + Unigine::Math::Vec3(0.0, 0.0, 50.0));

            if (brush_decal->isEnabledSelf())
                brush_decal->setEnabled(false);
        }
        // dont allow painting at the same time as sampling
        return;
    }

    if (paint_target == terrain_manipulator::PaintTarget::Height || paint_target == terrain_manipulator::PaintTarget::Albedo)
    {
        const auto mouse_coord = Unigine::Input::getMousePosition();
        bool fetched = landscape_fetch->intersectionForce(player->getPosition(),
            player->getPosition() + Unigine::Math::Vec3(player->getDirectionFromMainWindow(mouse_coord.x, mouse_coord.y)) * 10000.0);

        if (fetched)
        {
            brush_decal->setPosition(landscape_fetch->getPosition() + Unigine::Math::Vec3(0.0, 0.0, 50.0));
            if (!brush_decal->isEnabledSelf())
                brush_decal->setEnabled(true);


            if (Unigine::Input::isMouseButtonPressed(Unigine::Input::MOUSE_BUTTON::MOUSE_BUTTON_LEFT))
            {

                switch (paint_target)
                {
                case terrain_manipulator::PaintTarget::Albedo:
                    //albedo_painter->paintAt(landscape_fetch->getPosition());
                    break;
                case terrain_manipulator::PaintTarget::Height:
                {
                    terrain_manipulator::BrushOperationData brush_data;
                    brush_data.brush_height = brush_height;
                    brush_data.brush_size = brush_size;
                    brush_data.brush_rotation = brush_angle;
                    brush_data.brush_opacity = brush_opacity;
                    brush_data.height_blend_mode = height_blend_mode;
                    brush_data.modify_heights = true;
                    brush_data.brush_material = m_terrain_manipulator.getTerrainTileBrush(brush_texture);

                    m_terrain_manipulator.PaintTerrainHeightAt(landscape_fetch->getPosition(), brush_data);
                    break;
                }
                default: break;
                }
            }
        }
    }

}


void terrain_painting::set_terrain_paint_mode(bool terrain_paint_mode_enabled)
{
    Unigine::Log::message("terrain edit mode %s\n", terrain_paint_mode_enabled ? "enabled" : "disabled");

    if (terrain_paint_mode_enabled)
        create_brush_decal(brush_texture);
    else
        cleanup_brush_decal();

    m_edit_mode_enabled = terrain_paint_mode_enabled;

    // allow users of this class to listen to changes to this.
    // no multiple subscription at this point
    if (m_terrain_paint_mode_enabled_cb)
        m_terrain_paint_mode_enabled_cb(terrain_paint_mode_enabled);
}

void terrain_painting::load_brush_textures()
{
    // where to get brush data from?
    std::vector<std::string> brush_texture_files;
    brush_texture_files.push_back("circle_soft.texture");
    brush_texture_files.push_back("circle_medium.texture");
    brush_texture_files.push_back("circle_hard.texture");


    for (int i = 0; i < brush_texture_files.size(); ++i)
    {
        auto image = Unigine::Image::create();
        auto found = image->load(Unigine::FileSystem::resolvePartialVirtualPath((brush_texture_files[i].c_str())));
        if (found)
        {
            auto texture = Unigine::Texture::create();
            texture->create(image);
            brush_textures.push_back(texture);

            image->resize(32, 32);
            brush_textures_icons.push_back(image);
        }
    }
    if (brush_textures.size() > 0)
        brush_texture = brush_textures[0];
}

void terrain_painting::create_brush_decal(Unigine::TexturePtr in_brush_texture)
{
    if (!brush_decal || brush_decal.isDeleted())
    {
        brush_decal = Unigine::DecalOrtho::create();
        brush_decal->setRadius(100.f);
        // need terrain intersection mask to avoid showing this on top of other objects
        // TODO" define the mask values
        brush_decal->setIntersectionMask(0x01);

        brush_decal_material = brush_decal->getMaterialInherit();
        brush_decal_material->setTexture("albedo", in_brush_texture);

        brush_decal->setMaterial(brush_decal_material);
        brush_decal->setWidth(brush_size);
        brush_decal->setHeight(brush_size);
        brush_decal->setRotation(Unigine::Math::quat(0.f, 0.f, -brush_angle), true);
        brush_decal->setOpacity(brush_opacity);
    }
}

void terrain_painting::cleanup_brush_decal()
{
    if (brush_decal)
    {
        brush_decal.deleteLater();
    }
}



void terrain_painting::set_brush_texture(Unigine::TexturePtr in_brush_texture)
{
    brush_texture = in_brush_texture;
    if(brush_decal_material)
        brush_decal_material->setTexture("albedo", in_brush_texture);
}

void terrain_painting::set_brush_size(float in_brush_size)
{
    brush_size = std::max(in_brush_size, 0.1f);

    if(brush_decal)
    {
        brush_decal->setWidth(brush_size);
        brush_decal->setHeight(brush_size);
    }
}

void terrain_painting::set_brush_angle(float in_brush_angle)
{
    brush_angle = in_brush_angle;
    if (brush_decal)
        brush_decal->setRotation(Unigine::Math::quat(0.f, 0.f, -brush_angle), true);
}

void terrain_painting::set_brush_opacity(float in_brush_opacity)
{
    brush_opacity = std::clamp(in_brush_opacity, 0.0f, 1.0f);
    if (brush_decal)
        brush_decal->setOpacity(brush_opacity);
}