namespace
{

    static const std::string TERRAIN_NAME_PREFIX = "terrain";
    // TODO: These should be configurbale in some way, probably from the ini file to start with
    static const auto TERRAIN_ALBEDO_IMAGE_NAME = "shared_terrain_albedo.dds";
    static const auto TERRAIN_HEIGHT_IMAGE_NAME = "shared_terrain_height.tif";

    // Each terrain lmap will be this size and resolution, should probably be configurable.
    // Note that we use the same resolution for heights and textures. 
    static const int TERRAIN_SIZE = 4096;
    static const int TERRAIN_RESOLUTION = 4096;


    static const double PADDING_DISTANCE = 1000;
}


terrain_creation::terrain_creation(terrain_creator &terrain_creator)
    :m_terrain_creator(terrain_creator)
{

}

terrain_creation::~terrain_creation()
{
    
}

void terrain_creation::ExpandTerrainToFitBoundsOfNodes(std::vector<Unigine::NodePtr> nodes_to_expand_to,
    std::string          file_path_to_lmap)
{
    for (auto &node : nodes_to_expand_to)
    {
        ExpandTerrainToFitBoundsOfNode(
            node, file_path_to_lmap, Unigine::Math::ivec2(TERRAIN_SIZE, TERRAIN_SIZE), Unigine::Math::ivec2(TERRAIN_RESOLUTION, TERRAIN_RESOLUTION));
    }
}


// Somewhat crude method to determine where to create terrain tiles
// we define a fixed absolute grid of tiles at a fixed size starting at 0,0
// we determine which of the tiles in this grid should be created.
// We want to make sure that we have terrain for some distance around each segment, so
// we take the bounding box of each segment mesh and extend it by some padding amount
// in each direction. Then we want to ensure there is a terrain tile being created at each
// corner of that box. The bounds may be larger than our tile size, so we need to also
// check for positions within the bounding box based on the size.
// We work out how many sample points we need to make to ensure this, and then test each
// sample point to see if there is already terrain existing, else we will request that terrain be built.

// TODO: each tile could be created at a different base height, need to check all segments to get a global min
// and then set that in all requests
 void terrain_creation::ExpandTerrainToFitBoundsOfNode(Unigine::NodePtr     node_to_expand_to,
        std::string          file_path_to_lmap,
        Unigine::Math::ivec2 size,
        Unigine::Math::ivec2 resolution)
{
    auto node_bounds = node_to_expand_to->getWorldBoundBox();
    auto node_size = node_bounds.getSize();

    auto min = node_bounds.minimum;
    auto max = node_bounds.maximum;

    std::vector<Unigine::Math::dvec2> sample_points;

    // Extend our bounding box by the padding distance in each direction so that we can ensure a tile will be there.
    auto sample_min = Unigine::Math::dvec2(min) - Unigine::Math::dvec2(PADDING_DISTANCE, PADDING_DISTANCE);
    auto sample_max = Unigine::Math::dvec2(max) + Unigine::Math::dvec2(PADDING_DISTANCE, PADDING_DISTANCE);
    auto sample_size = Unigine::Math::dvec2(node_size) + Unigine::Math::dvec2(2 * PADDING_DISTANCE, 2 * PADDING_DISTANCE);

    // determine our sample points based on our terrain file size.
    // we want to split up our bounding box so that the maximum sample distance is one tile.
    // so we round up our division.
    auto sample_count_x = static_cast<int>(std::ceil(sample_size.x / size.x));
    auto sample_count_y = static_cast<int>(std::ceil(sample_size.y / size.y));

    // calculate the step outside, we will loop using integers. 
    auto sample_step_x = sample_size.x / sample_count_x;
    auto sample_step_y = sample_size.y / sample_count_y;

    for (auto i = 0; i <= sample_count_x; i++)
    {
        double x = sample_min.x + i * sample_step_x;
        for (auto j = 0; j <= sample_count_y; j++)
        {
            double y = sample_min.y + j * sample_step_y;
            sample_points.push_back(Unigine::Math::dvec2(x, y));
        }
    }

    for (auto point : sample_points)
    {
        auto nearest_terrain_x_coord = static_cast<int>(std::floor(point.x / size.x));
        auto nearest_terrain_y_coord = static_cast<int>(std::floor(point.y / size.y));

        auto nearest_terrain_origin = Unigine::Math::dvec3(nearest_terrain_x_coord * size.x, nearest_terrain_y_coord * size.y, 0);

        // if we find terrain underneath us or we find a terrain node with origin we are about to create then ignore this point
        if (TerrainTestFetchAtPosition(point) || CheckTerrainTileWithOriginExists(nearest_terrain_origin))
            continue;

        m_terrain_creator.RequestTerrainCreation(file_path_to_lmap, Unigine::Math::ivec2(nearest_terrain_x_coord, nearest_terrain_y_coord), nearest_terrain_origin, size, resolution, min.z);

    }

}



void terrain_creation::RemoveAllTerrainNodes()
{
    Unigine::ObjectLandscapeTerrainPtr parent_terrain = Unigine::Landscape::getActiveTerrain();
    if (parent_terrain)
    {
        for (int i = 0; i < parent_terrain->getNumChildren(); i++)
        {
            auto terrain = parent_terrain->getChild(i);
            terrain.deleteLater();
        }
    }
}
