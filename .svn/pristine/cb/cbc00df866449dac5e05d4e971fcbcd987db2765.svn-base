#pragma once

#include <UnigineObjects.h>
#include <UniginePlugin.h>

class CollapsibleWidget;

class pull_terrain_to_surface_gui
{
public:
    using ApplyOldFunc = std::function<void(float flat_distance, float falloff_distance, int target_layer_order)>;
    using ApplyFunc = std::function<void(float flat_distance, float falloff_distance, float bias, float smoothing, int target_layer_order)>;
    using PullTargetModeFunc = std::function<void(int pull_target_mode)>;

    pull_terrain_to_surface_gui(
        Unigine::GuiPtr translation_gui,
        float initial_flat_value,
        float initial_falloff_value,
        float initial_bias_value,
        float initial_smoothing_value,
        int initial_layer_order = 0,
        int initial_pull_target_mode = 0);

    Unigine::WidgetPtr GetWidget();

    void Show();
    void Hide();

    void UpdateUI(std::vector<Unigine::NodePtr> selected_nodes);
    void SetApplyCallbackOld(ApplyOldFunc cb) { m_apply_old_cb = cb; }
    void SetApplyCallback(ApplyFunc cb) { m_apply_cb = cb; }
    void SetPullTargetModeCallback(PullTargetModeFunc cb) { m_pull_target_mode_cb = cb; }

    // update UI values externally without firing change callbacks
    void SetPullTargetMode(int in_pull_target_mode);

private:
    void ShowTargetLayerEntry();
    void HideTargetLayerEntry();
    void ShowPullTargetModeEntry();
    void HidePullTargetModeEntry();

private:
    std::shared_ptr<CollapsibleWidget> m_collapsible_widget;
    ApplyOldFunc m_apply_old_cb;
    ApplyFunc m_apply_cb;
    PullTargetModeFunc m_pull_target_mode_cb;

    Unigine::WidgetPtr CreateMainContentWidget(
        Unigine::GuiPtr translation_gui,
        float initial_flat_value,
        float initial_falloff_value,
        float initial_bias_value,
        float initial_smoothing_value,
        int initial_layer_order,
        int initial_pull_target_mode); // initial surface string/property

    // to allow configurable hiding
    Unigine::WidgetHBoxPtr m_target_layer_hbox;
    Unigine::WidgetHBoxPtr m_pull_target_mode_hbox;

    // to allow external setting of the value
    Unigine::WidgetComboBoxPtr m_pull_target_mode_selection;

    Unigine::EventConnection pull_target_mode_selection_callback;
};
