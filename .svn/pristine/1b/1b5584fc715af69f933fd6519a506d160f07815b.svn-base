namespace
{
    static int round_up(int value, int round)
    {
        int result = ((value + (round - 1)) / round) * round;
        return result;
    }

    static int group_threads(int width, int kernel_size)
    {
        int result = __max(1, round_up(width, kernel_size) / kernel_size);
        return result;
    }

    static Unigine::Math::ivec2 round_up(Unigine::Math::ivec2 value, Unigine::Math::ivec2 round)
    {
        Unigine::Math::ivec2 result = ((value + (round - 1)) / round) * round;
        return result;
    }

}

terrain_to_surface::terrain_to_surface(terrain_manipulator& terrain_manipulator)
  : m_terrain_manipulator(terrain_manipulator)
{
    // this is not available in the unigine editor, should be getting passed in.
    Unigine::EngineWindowPtr main_window = Unigine::WindowManager::getMainWindow();
    auto                     gui         = main_window->getGui();

    // surface property to look for to pull terrain
    // apparently was not found in the constructor which is possible filesystem timing issues because our data folder is
    // mounted instead of by default.
    // m_terrain_target_surface_prop = Unigine::Properties::findProperty("terrain_surface");

    float init_flat_distance      = 30;
    float init_falloff_distance   = 30;
    float initial_bias_value      = 0.0f;
    float initial_smoothing_value = 0.5f;
    int   init_layer_order        = 0;
    int   init_pull_target_mode   = 0;

    m_terrain_to_surface_gui = std::make_unique<pull_terrain_to_surface_gui>(gui,
                                                                             init_flat_distance,
                                                                             init_falloff_distance,
                                                                             initial_bias_value,
                                                                             initial_smoothing_value,
                                                                             init_layer_order,
                                                                             init_pull_target_mode);

    m_terrain_to_surface_gui->SetApplyCallback(
      [this](float flat_size, float falloff_size, float bias, float smoothing, int target_layer_order)
      {
          std::vector<Unigine::NodePtr> selection;

          if (m_get_selection_func)
              selection = m_get_selection_func();

          // this should really just put the request onto a queue to be serviced in the update loop
          // need to look at when we should get the current selection, seems a bit ugly for it to get the selection
          // here.
          RaiseTerrainToSelection(selection, flat_size, falloff_size, bias, smoothing, target_layer_order);
      });

    m_terrain_to_surface_gui->SetPullTargetModeCallback(
      [this](int pull_target_mode) { this->m_pull_target_mode = static_cast<PullTargetMode>(pull_target_mode); });
}

terrain_to_surface::~terrain_to_surface()
{
}

