{
    // disable our events before updating
    height_brush_angle_edit_line_callback.setEnabled(false);
    height_brush_angle_edit_line->setText(Unigine::String::ftoa(in_brush_angle));
    height_brush_angle_edit_line_callback.setEnabled(true);
