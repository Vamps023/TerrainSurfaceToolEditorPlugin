#pragma once

#include "terrain_manipulator.h"
#include "terrain_paint_gui.h"

#include <UnigineObjects.h>
#include <UnigineDecals.h>
#include <cassert>
#include <string>
#include <vector>
#include <regex>



class terrain_painting
{
public:
    terrain_painting(terrain_manipulator &terrain_manipulator);
    ~terrain_painting();

    void update();

    void show_ui() { m_terrain_paint_gui->Show(); }
    void hide_ui() { m_terrain_paint_gui->Hide(); }

    Unigine::WidgetPtr get_gui_wiget() { return m_terrain_paint_gui->GetWidget(); }
    bool is_terrain_painting_enabled() { return m_edit_mode_enabled; }

    void set_terrain_painting_enabled_cb(std::function<void(bool terrain_paint_mode_enabled)> cb) { m_terrain_paint_mode_enabled_cb = cb; }
private:
    terrain_manipulator &m_terrain_manipulator;

    std::unique_ptr<terrain_paint_gui> m_terrain_paint_gui;

    bool m_edit_mode_enabled = false;

    void set_terrain_paint_mode(bool terrain_paint_mode_enabled);
    std::function<void(bool terrain_paint_mode_enabled)> m_terrain_paint_mode_enabled_cb;

    // Paint Target
    terrain_manipulator::PaintTarget paint_target{ terrain_manipulator::PaintTarget::Height };
    //target_mask for painting to detail masks?

    // Brush Data
    terrain_manipulator::HeightBlendMode height_blend_mode{ terrain_manipulator::HeightBlendMode::Alpha };
    Unigine::TexturePtr brush_texture;
    float brush_size{ 1.0f };
    float brush_spacing{ 0.2f };
    float brush_angle{ 0.0f };
    float brush_opacity{ 1.0f };
    float brush_height{ 1.0f };
    // colour?
    // colour intensity?

    // set of possible brush textures
    Unigine::Vector<Unigine::TexturePtr> brush_textures;
    Unigine::Vector<Unigine::ImagePtr> brush_textures_icons;
    void load_brush_textures();

    // painting preview
    Unigine::DecalOrthoPtr brush_decal;
    Unigine::MaterialPtr   brush_decal_material;
    void create_brush_decal(Unigine::TexturePtr in_brush_texture);
    void cleanup_brush_decal();

    void set_brush_texture(Unigine::TexturePtr in_brush_texture);
    void set_brush_size(float in_brush_size);
    void set_brush_angle(float in_brush_angle);
    void set_brush_opacity(float in_brush_opacity);

    Unigine::LandscapeFetchPtr landscape_fetch;

};

