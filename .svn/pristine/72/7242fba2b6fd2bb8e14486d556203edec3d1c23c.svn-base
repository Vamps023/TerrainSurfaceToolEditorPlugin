#pragma once

#include <UnigineObjects.h>
#include <UniginePlugin.h>

class CollapsibleWidget;

class terrain_paint_gui
{
public:
    terrain_paint_gui(Unigine::GuiPtr translation_gui, Unigine::Vector<Unigine::ImagePtr> brush_icons, float initial_size = 1.0f, float initial_angle = 0.0f, float initial_height = 1.0f, float initial_opacity = 1.0f, int initial_blend_mode = 0 );

    Unigine::WidgetPtr GetWidget();

    void Show();
    void Hide();

    void UpdateUI(std::vector<Unigine::NodePtr> nodes);

    // Edit mode enable 
    void SetToggleCallback(std::function<void(bool edit_mode_enabled)> cb) { m_toggle_cb = cb; }

    // Brush Settings
    void SetSelectBrushTextureCallback(std::function<void(int texture_index)> cb) { m_select_brush_texture_cb = cb; }
    void SetBrushSizeCallback(std::function<void(float brush_size)> cb) { m_brush_size_cb = cb; }
    void SetBrushAngleCallback(std::function<void(float brush_angle)> cb) { m_brush_angle_cb = cb; }
    void SetBrushHeightCallback(std::function<void(float brush_height)> cb) { m_brush_height_cb = cb; }
    void SetBrushOpacityCallback(std::function<void(float brush_opacity)> cb) { m_brush_opacity_cb = cb; }
    void SetHeightBlendModeCallback(std::function<void(int height_blend_mode)> cb) { m_height_blend_mode_cb = cb; }

    // update UI values externally without firing change callbacks
    void set_brush_size(float in_brush_size);
    void set_brush_angle(float in_brush_angle);
    void set_brush_height(float in_brush_height);
    void set_brush_opacity(float in_brush_opacity);


private:
    std::shared_ptr<CollapsibleWidget> m_collapsible_widget;

    std::function<void(bool edit_mode_enabled)> m_toggle_cb;

    std::function<void(int texture_index)> m_select_brush_texture_cb;
    std::function<void(float brush_size)> m_brush_size_cb;
    std::function<void(float brush_angle)> m_brush_angle_cb;
    std::function<void(float brush_height)> m_brush_height_cb;
    std::function<void(float brush_opacity)> m_brush_opacity_cb;
    std::function<void(int height_blend_mode)> m_height_blend_mode_cb;


    Unigine::WidgetPtr CreateMainContentWidget(Unigine::GuiPtr translation_gui, float initial_size, float initial_angle, float initial_height, float initial_opacity, int initial_blend_mode);

    Unigine::Vector<Unigine::ImagePtr> brush_textures_icons;


    // some gui components can be updated externally, so we need to keep track of them
    Unigine::WidgetEditLinePtr height_brush_size_edit_line;
    //Unigine::WidgetEditLinePtr height_brush_spacing_edit_line;
    Unigine::WidgetEditLinePtr height_brush_angle_edit_line;
    Unigine::WidgetEditLinePtr height_brush_height_edit_line;
    Unigine::WidgetEditLinePtr height_brush_opacity_edit_line;
    //Unigine::WidgetEditLinePtr height_brush_height_scale_edit_line;
    //Unigine::WidgetComboBoxPtr height_blend_mode_combo_box;

    //keep track of our events as we want to disconnect them when updating the values externally
    Unigine::EventConnection height_brush_size_edit_line_callback;
    //Unigine::EventConnection height_brush_spacing_edit_line_callback;
    Unigine::EventConnection height_brush_angle_edit_line_callback;
    Unigine::EventConnection height_brush_height_edit_line_callback;
    Unigine::EventConnection height_brush_opacity_edit_line_callback;
    //Unigine::EventConnection height_brush_height_scale_edit_line_callback;
    //Unigine::EventConnection height_blend_mode_combo_box_callback;

    /*Unigine::EventConnection albedo_brush_size_edit_line_callback;
    Unigine::EventConnection albedo_brush_spacing_edit_line_callback;
    Unigine::EventConnection albedo_brush_angle_edit_line_callback;
    Unigine::EventConnection albedo_brush_opacity_edit_line_callback;
    Unigine::EventConnection albedo_brush_color_r_edit_line_callback;
    Unigine::EventConnection albedo_brush_color_g_edit_line_callback;
    Unigine::EventConnection albedo_brush_color_b_edit_line_callback;
*/
};

