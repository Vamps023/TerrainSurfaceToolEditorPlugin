int terrain_creator::init()
{
    // anything to do here?
    // we might want to get a reference to somewhere we can post some progress data to for the ui during lmap creation?
    return 1;
}

int terrain_creator::update()
{
    // trying just one per update
    if (!m_terrain_creation_request.empty())
    {
        CreateTerrainForPosition(m_terrain_creation_request.front());
        m_terrain_creation_request.pop_front();
        m_terrain_created = true;
    }
    else
        m_terrain_created = false;
    return 1;
}

int terrain_creator::shutdown()
{
    // remove all event subscriptions on shutdown
    //connections.disconnectAll();
    m_terrain_creation_request.clear();
    m_terrain_creation_data_buffer = {};

    return 1;
}