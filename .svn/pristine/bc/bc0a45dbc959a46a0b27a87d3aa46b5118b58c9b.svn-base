terrain_creation_gui::terrain_creation_gui()
{

    // translation dictionary is currently added to the world builder main gui, which happens to also be the main window gui
    // so to provide translations we need to translate through that,
    // for now, instead of getting the world builder GUI, we are getting the main window ourselves.
    // maybe using .ui files makes this a bit cleaner?
    Unigine::EngineWindowPtr main_window = Unigine::WindowManager::getMainWindow();
    auto gui = main_window->getGui();

    // this is our main collabisble widget that we are creating for someone to add to a gui somewhere.
    m_collapsible_widget = std::shared_ptr<CollapsibleWidget>(new CollapsibleWidget(gui->translate("Create Terrain")));
    // initialise our gui to hidden
    m_collapsible_widget->hide();

    // the create a container just for the collapsible content widget
    // we don't do anything special on this widget, we will leave it to the widgets we add to it to make it
    // easier to separate those out if they were to go somewhere else.
    auto collapsible_content_container = Unigine::WidgetVBox::create(0, 2);
    m_collapsible_widget->addContentWidget(collapsible_content_container);

    // the actual container of our components
    auto main_content_container = Unigine::WidgetVBox::create(0, 4);
    //main_content_container->setFontColor(unigine2_ui::colors::TAB_BOX_FONT_COLOR);
    collapsible_content_container->addChild(main_content_container);


   // container for our creation info
    /* disabled for now, no user control 
    auto creation_info_container = Unigine::WidgetVBox::create(0, 4);
    auto size_value_container = Unigine::WidgetHBox::create(5, 0);
    auto resolution_value_container = Unigine::WidgetHBox::create(5, 0);

    // possibly add padding value?

    auto size_label = unigine2_ui::CreateWidgetLabel(gui->translate("Tile Size"), 60, 20);
    size_label->setTextAlign(Unigine::Gui::ALIGN_LEFT); //| Unigine::Gui::ALIGN_BOTTOM
    // edit line
    auto size_edit = unigine2_ui::CreatePropertyEditLineLabel(40, 20, 1, true);
    size_edit->setValidator(Unigine::Gui::VALIDATOR_FLOAT);

    auto resolution_label = unigine2_ui::CreateWidgetLabel(gui->translate("Tile Resolution"), 60, 20);
    resolution_label->setTextAlign(Unigine::Gui::ALIGN_LEFT); // | Unigine::Gui::ALIGN_BOTTOM
    // edit line
    auto resolution_edit = unigine2_ui::CreatePropertyEditLineLabel(40, 20, 1, true);
    resolution_edit->setValidator(Unigine::Gui::VALIDATOR_FLOAT);

    size_value_container->addChild(size_label, Unigine::Gui::ALIGN_EXPAND);
    size_value_container->addChild(size_edit, Unigine::Gui::ALIGN_EXPAND);
    resolution_value_container->addChild(resolution_label, Unigine::Gui::ALIGN_EXPAND);
    resolution_value_container->addChild(resolution_edit, Unigine::Gui::ALIGN_EXPAND);
    creation_info_container->addChild(size_value_container, Unigine::Gui::ALIGN_EXPAND);
    creation_info_container->addChild(resolution_value_container, Unigine::Gui::ALIGN_EXPAND);

    main_content_container->addChild(creation_info_container, Unigine::Gui::ALIGN_EXPAND);
    */

    // potentially add path selection to find the height/albedo images to use for creation
    // modes -> none, default shared, custom shared, auto selection from path (QGIS height exports)?
    // maybe should use entry and default it to our supplied one, rather than give a default option.
    // should be able to carve out some of the import ground height/image gui components to reuse here.

    // potentially add ability to create specific tile?
    // potentially add ability to create tiles to fit other objects? but how to select without deselecting the terrain node showing our gui?


    // container for creating the terrain
    auto buttons_container = Unigine::WidgetHBox::create(5,0);

    auto create_button = Unigine::WidgetButton::create();
    create_button->setWidth(40);
    create_button->setHeight(30);
    create_button->setText(gui->translate("Create"));
    create_button->setToolTip(gui->translate("Create new terrain as required to encompass the track."));
    create_button->setTextAlign(Unigine::Gui::ALIGN_CENTER);
    create_button->arrange();

    create_button->getEventClicked().connectUnsafe(
        [this](const Unigine::WidgetPtr &execute_button_widget, int mouse_buttons)
        {

            if (m_execute_cb)
                m_execute_cb();
        }
    );

    buttons_container->addChild(create_button, Unigine::Gui::ALIGN_RIGHT);
    // possibly include a remove all terrain button
    main_content_container->addChild(buttons_container, Unigine::Gui::ALIGN_EXPAND);

}

Unigine::WidgetPtr terrain_creation_gui::GetWidget()
{
    return Unigine::checked_ptr_cast<Unigine::Widget>(m_collapsible_widget->get());
}

void terrain_creation_gui::Show()
{
    m_collapsible_widget->show();
}

void terrain_creation_gui::Hide()
{
    m_collapsible_widget->hide();
}

void terrain_creation_gui::UpdateUI(std::vector<Unigine::NodePtr> nodes)
{

}
